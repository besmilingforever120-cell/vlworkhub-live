{
  "name": "vlworkhub",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently -n main,care,hr,ursafe -c green,yellow,magenta,blue \"npm run dev:main\" \"npm run dev:care\" \"npm run dev:hr\" \"npm run dev:ursafe\"",
    "dev:main": "npm run dev -w @vlworkhub/main-platform",
    "dev:care": "npm run dev -w @vlworkhub/care-app",
    "dev:hr": "npm run dev -w @vlworkhub/hr-app",
    "dev:ursafe": "npm run dev -w @vlworkhub/ursafe-app",
    "dev:api": "npm run dev -w @vlworkhub/api",
    "dev:api:serve": "npm run build -w @vlworkhub/auth && npm run build -w @vlworkhub/api && npm run start -w @vlworkhub/api",
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "pdfjs-dist": "^4.2.67",
    "react-pdf": "^9.2.1"
  }
}
