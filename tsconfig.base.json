{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@vlworkhub/ui": ["packages/ui/src/index.ts"],
      "@vlworkhub/ui/*": ["packages/ui/src/*"],
      "@vlworkhub/config": ["packages/config/index.ts"],
      "@vlworkhub/config/*": ["packages/config/*"],
      "@vlworkhub/types": ["packages/types/index.ts"]
    }
  }
}
