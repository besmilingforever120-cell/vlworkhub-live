NODE_ENV=development
# Required in production. Keep empty in templates and inject a real value via environment.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
COOKIE_DOMAIN=
API_PORT=8080
TRUST_PROXY_HOPS=0
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_ROOT_URL=http://localhost:3000
NEXT_PUBLIC_CARE_URL=http://localhost:3001
NEXT_PUBLIC_HR_URL=http://localhost:3002
NEXT_PUBLIC_URSAFE_URL=http://localhost:3003

# Local development (default)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vlworkhub

# Docker environment (used when running via docker-compose)
# DATABASE_URL=postgres://postgres:postgres@vlworkhub-postgres:5432/vlworkhub
