NODE_ENV=development
# Required in production. Keep empty in templates and inject a real value via environment.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# If the value contains '$', escape it as '$$' when used in docker-compose .env files.
JWT_SECRET=
# Email settings encryption key — required in production. Must be a long random string.
EMAIL_SETTINGS_ENCRYPTION_KEY=
COOKIE_DOMAIN=
API_PORT=8080
TRUST_PROXY_HOPS=0
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
# Internal service URL used by app containers to call API over Docker network.
API_INTERNAL_URL=http://api:8080
# Public/base URLs (single source of truth across all apps).
MAIN_PLATFORM_URL=http://192.168.1.47:3000
HR_APP_URL=http://192.168.1.47:3002
CARE_APP_URL=http://192.168.1.47:3001
URSAFE_APP_URL=http://192.168.1.47:3003
API_BASE_URL=http://192.168.1.47:8080
# Browser origins allowed by API CORS checks.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# PostgreSQL settings (used by docker-compose and local DB clients)
POSTGRES_DB=vlworkhub
POSTGRES_USER=vlworkhub
# REQUIRED: set a strong secret (at least 32 chars). Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Local development (DBeaver/psql on host)
DATABASE_URL=postgres://vlworkhub:${POSTGRES_PASSWORD}@localhost:5432/vlworkhub

# Docker environment (used when running via docker-compose)
# DATABASE_URL=postgres://vlworkhub:${POSTGRES_PASSWORD}@vlworkhub-postgres:5432/vlworkhub
