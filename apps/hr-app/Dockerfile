FROM node:20-alpine AS deps
WORKDIR /app

ARG MAIN_PLATFORM_URL
ARG HR_APP_URL
ARG CARE_APP_URL
ARG URSAFE_APP_URL
ARG API_BASE_URL
ARG NEXT_PUBLIC_MAIN_APP_URL
ARG NEXT_PUBLIC_ROOT_URL
ARG NEXT_PUBLIC_HR_APP_URL
ARG NEXT_PUBLIC_CARE_APP_URL
ARG NEXT_PUBLIC_URSAFE_APP_URL
ARG NEXT_PUBLIC_API_URL
ENV MAIN_PLATFORM_URL=$MAIN_PLATFORM_URL
ENV HR_APP_URL=$HR_APP_URL
ENV CARE_APP_URL=$CARE_APP_URL
ENV URSAFE_APP_URL=$URSAFE_APP_URL
ENV API_BASE_URL=$API_BASE_URL
ENV NEXT_PUBLIC_MAIN_APP_URL=$NEXT_PUBLIC_MAIN_APP_URL
ENV NEXT_PUBLIC_ROOT_URL=$NEXT_PUBLIC_ROOT_URL
ENV NEXT_PUBLIC_HR_APP_URL=$NEXT_PUBLIC_HR_APP_URL
ENV NEXT_PUBLIC_CARE_APP_URL=$NEXT_PUBLIC_CARE_APP_URL
ENV NEXT_PUBLIC_URSAFE_APP_URL=$NEXT_PUBLIC_URSAFE_APP_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

COPY package.json package-lock.json ./
COPY apps ./apps
COPY packages ./packages
COPY services ./services
COPY tsconfig.base.json ./

RUN npm install

FROM node:20-alpine AS builder
WORKDIR /app

ARG MAIN_PLATFORM_URL
ARG HR_APP_URL
ARG CARE_APP_URL
ARG URSAFE_APP_URL
ARG API_BASE_URL
ARG NEXT_PUBLIC_MAIN_APP_URL
ARG NEXT_PUBLIC_ROOT_URL
ARG NEXT_PUBLIC_HR_APP_URL
ARG NEXT_PUBLIC_CARE_APP_URL
ARG NEXT_PUBLIC_URSAFE_APP_URL
ARG NEXT_PUBLIC_API_URL
ENV MAIN_PLATFORM_URL=$MAIN_PLATFORM_URL
ENV HR_APP_URL=$HR_APP_URL
ENV CARE_APP_URL=$CARE_APP_URL
ENV URSAFE_APP_URL=$URSAFE_APP_URL
ENV API_BASE_URL=$API_BASE_URL
ENV NEXT_PUBLIC_MAIN_APP_URL=$NEXT_PUBLIC_MAIN_APP_URL
ENV NEXT_PUBLIC_ROOT_URL=$NEXT_PUBLIC_ROOT_URL
ENV NEXT_PUBLIC_HR_APP_URL=$NEXT_PUBLIC_HR_APP_URL
ENV NEXT_PUBLIC_CARE_APP_URL=$NEXT_PUBLIC_CARE_APP_URL
ENV NEXT_PUBLIC_URSAFE_APP_URL=$NEXT_PUBLIC_URSAFE_APP_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

COPY --from=deps /app /app

RUN test -n "$MAIN_PLATFORM_URL" && test -n "$HR_APP_URL" && test -n "$CARE_APP_URL" && test -n "$URSAFE_APP_URL" && test -n "$API_BASE_URL" && test -n "$NEXT_PUBLIC_MAIN_APP_URL" && test -n "$NEXT_PUBLIC_API_URL"

RUN npm run build -w @vlworkhub/hr-app

FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production

COPY --from=builder /app /app

EXPOSE 3002

CMD ["npm", "run", "start", "-w", "@vlworkhub/hr-app"]